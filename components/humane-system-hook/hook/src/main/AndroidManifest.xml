<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:sharedUserId="android.uid.system"
    tools:ignore="Deprecated">

    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <application
        android:allowBackup="false"
        android:label="PenumbraHook">
        <!-- No activities, no receivers, no services.
             This APK exists only to be loaded into other processes
             via sharedLibraryFiles. -->

        <!-- Authoritative list of packages the injector should target at boot.
             Comma-separated Android package names. -->
        <meta-data
            android:name="com.penumbraos.hook.TARGET_PACKAGES"
            android:value="hu.ma.ne.ironman,humane.experience.onboarding,humane.experience.photography,hu.ma.ne.krypto,humane.experience.systemnavigation,humane.experience.settings,humane.connectivity.esimlpa" />
    </application>
</manifest>
